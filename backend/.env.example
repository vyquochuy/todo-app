# Backend — Environment Variables
# Copy this file to .dev.vars for local development with wrangler

# Cloudflare D1 credentials (used only by drizzle-kit for remote migrations)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_DATABASE_ID=your_d1_database_id_here
CLOUDFLARE_D1_TOKEN=your_d1_api_token_here

# Runtime environment (set via wrangler.toml [vars] in production)
ENV=development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your_jwt_signing_secret_here
